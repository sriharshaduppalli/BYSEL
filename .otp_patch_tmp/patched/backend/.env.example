DEBUG=True
DATABASE_URL=sqlite:///./bysel.db
API_HOST=0.0.0.0
API_PORT=8000

# CORS and auth hardening
# Comma-separated allowlist. Example:
# BYSEL_ALLOWED_ORIGINS=http://localhost:5173,https://app.bysel.com
BYSEL_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://10.0.2.2:5173
# Keep disabled in production. Enables legacy `user_id` header fallback when true.
ALLOW_USER_ID_HEADER_FALLBACK=false

# Token settings
AUTH_SECRET=change-this-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Access tokens carry jti/ver claims; token_version is server-enforced in DB.

# Auth rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS=6
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
REFRESH_RATE_LIMIT_ATTEMPTS=12
REFRESH_RATE_LIMIT_WINDOW_SECONDS=60

# Soft login lockout (username+ip)
LOGIN_LOCKOUT_FAILURES=5
LOGIN_LOCKOUT_WINDOW_SECONDS=300
LOGIN_LOCKOUT_DURATION_SECONDS=300

# Debug auth observability (disable in production)
AUTH_DEBUG_ENDPOINTS_ENABLED=false
AUTH_DEBUG_TOKEN=

# OTP settings
FAST2SMS_API_KEY=
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
