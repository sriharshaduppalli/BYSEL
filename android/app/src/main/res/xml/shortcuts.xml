    <shortcut
        android:shortcutId="market_status"
        android:enabled="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:shortcutShortLabel="@string/shortcut_market_short"
        android:shortcutLongLabel="@string/shortcut_market_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.bysel.trader"
            android:targetClass="com.bysel.trader.MainActivity">
            <extra android:name="shortcut_action" android:value="market_status" />
        </intent>
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

    <!-- Shortcut 4: Price Alerts -->
    <shortcut
        android:shortcutId="price_alerts"
        android:enabled="true"
        android:icon="@drawable/ic_launcher_foreground"
        android:shortcutShortLabel="@string/shortcut_alerts_short"
        android:shortcutLongLabel="@string/shortcut_alerts_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.bysel.trader"
            android:targetClass="com.bysel.trader.MainActivity">
            <extra android:name="shortcut_action" android:value="price_alerts" />
        </intent>
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
