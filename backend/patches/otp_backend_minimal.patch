+def _send_otp_sms(mobile_number: str, otp_code: str) -> bool:
+    if not FAST2SMS_API_KEY:
+        logger.error("auth.otp.provider_not_configured")
+        return False
+
+    phone = mobile_number.replace("+91", "").strip()
+    if len(phone) != 10 or not phone.isdigit():
+        logger.warning("auth.otp.invalid_fast2sms_number mobile_number=%s", mobile_number)
+        return False
+
+    try:
+        payload = urllib.parse.urlencode({
+            "variables_values": otp_code,
+            "route": "otp",
+            "numbers": phone,
+        }).encode("utf-8")
+        request = urllib.request.Request(
+            "https://www.fast2sms.com/dev/bulkV2",
+            data=payload,
+            headers={
+                "authorization": FAST2SMS_API_KEY,
+                "Content-Type": "application/x-www-form-urlencoded",
+            },
+            method="POST",
+        )
+        with urllib.request.urlopen(request, timeout=15) as response:
+            body = json.loads(response.read().decode("utf-8"))
+        return body.get("return") is True or body.get("status_code") == 200
+    except Exception as exc:
+        logger.exception("auth.otp.sms_send_failed mobile_number=%s reason=%s", mobile_number, str(exc))
+        return False
