+def _normalize_mobile_number(value: str) -> str:
+    mobile_number = value.strip()
+    if not mobile_number:
+        raise HTTPException(status_code=400, detail="Mobile number is required")
+
+    if mobile_number.startswith("+"):
+        normalized = mobile_number
+    elif mobile_number.startswith("91") and len(mobile_number) == 12:
+        normalized = f"+{mobile_number}"
+    elif len(mobile_number) == 10 and mobile_number.isdigit():
+        normalized = f"+91{mobile_number}"
+    else:
+        raise HTTPException(status_code=400, detail="Invalid mobile number format")
+
+    if len(normalized) < 11:
+        raise HTTPException(status_code=400, detail="Invalid mobile number format")
+
+    return normalized
+
