+@router.post("/send-otp", response_model=OTPResponse)
+def send_otp(request: SendOTPRequest):
+    mobile_number = _normalize_mobile_number(request.mobile_number)
+
+    db: Session = SessionLocal()
+    try:
+        now = datetime.utcnow()
+        db.query(OTPModel).filter(OTPModel.expires_at <= now).delete()
+        db.commit()
+
+        recent_otps = db.query(OTPModel).filter(
+            OTPModel.mobile_number == mobile_number,
+            OTPModel.created_at >= now - timedelta(hours=1),
+        ).count()
+        if recent_otps >= 3:
+            raise HTTPException(status_code=429, detail="Too many OTP requests. Please try again later.")
+
+        otp_code = str(secrets.randbelow(900000) + 100000)
+        otp_hash = _hash_token(otp_code)
+
+        otp_record = OTPModel(
+            mobile_number=mobile_number,
+            otp_hash=otp_hash,
+            expires_at=now + timedelta(seconds=OTP_TTL_SECONDS),
+            created_at=now,
+        )
+        db.add(otp_record)
+        db.commit()
+
+        if not _send_otp_sms(mobile_number, otp_code):
+            db.delete(otp_record)
+            db.commit()
+            raise HTTPException(status_code=503, detail="OTP provider unavailable")
+
+        logger.info("auth.otp.sent mobile_number=%s", mobile_number)
+        return OTPResponse(
+            status="ok",
+            message="OTP sent successfully",
+            expires_in_seconds=OTP_TTL_SECONDS,
+        )
+    finally:
+        db.close()
+
